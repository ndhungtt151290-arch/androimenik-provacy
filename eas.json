{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_ENV": "staging"
      }
    },
    "production": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_AD_BANNER_ID": "ca-app-pub-XXXXXXXX/XXXXXXXX",
        "EXPO_PUBLIC_AD_INTERSTITIAL_ID": "ca-app-pub-XXXXXXXX/XXXXXXXX"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
